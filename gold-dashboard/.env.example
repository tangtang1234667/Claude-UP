# ── Gold Investment Dashboard Configuration ──────────────────────────────
# Copy this file to .env and fill in your values

# Required: Anthropic API Key for AI daily brief generation
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Server settings
HOST=0.0.0.0
PORT=8000

# Optional: Daily brief generation time (24-hour format, local timezone)
DAILY_BRIEF_HOUR=8
DAILY_BRIEF_MINUTE=30
